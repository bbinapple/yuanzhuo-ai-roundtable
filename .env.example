# Optional defaults for local development.
# The web UI is BYOK-first: users can leave these blank and enter settings in the browser.
# Do not share a maintainer-owned relay key in public deployments. Use relay defaults only in trusted local or self-controlled environments.
YUANZHUO_RELAY_BASE_URL=https://api.openai.com/v1
YUANZHUO_RELAY_API_KEY=
YUANZHUO_ANALYST_MODEL=gpt-4.1
YUANZHUO_EXECUTOR_MODEL=gpt-4.1
YUANZHUO_SECRETARY_MODEL=gpt-4.1
YUANZHUO_ENABLE_READ_LOCAL=
YUANZHUO_TOOL_CONFIRM_THRESHOLD=0
